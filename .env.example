PROJECT_NAME=spark-sglang-rag-demo

# SGLang chat model. Pick a model that fits your GPU.
SGLANG_MODEL=Qwen/Qwen3.6-35B-A3B
SGLANG_PORT=30000

# API behavior.
API_PORT=8000
FRONTEND_PORT=8501
SPARK_MASTER_URL=local[*]

# Retrieval.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chunks
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_MAX_WORDS=420
CHUNK_OVERLAP_WORDS=60
TOP_K=5

# OpenAI-compatible chat endpoint served by SGLang.
LLM_BASE_URL=http://sglang:30000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3.6-35B-A3B
